    {
      "parameters": {
        "jsCode": "const results = [];\nfor (const item of items) {\n  const contacts = item.json.people || item.json.contacts || [];\n  for (const contact of contacts) {\n    results.push({\n      json: {\n        contact_id: contact.id,\n        first_name: contact.first_name || \"\",\n        last_name: contact.last_name || \"\",\n        designation: contact.title || contact.designation || \"\",\n        linkedin_url: contact.linkedin_url || \"\",\n        company_name: contact.organization?.name || \"\",\n        website: contact.organization?.primary_domain || contact.organization?.domain || \"\"\n      }\n    });\n  }\n}\nreturn results;"
      },

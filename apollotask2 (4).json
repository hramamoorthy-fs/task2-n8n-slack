    {
      "parameters": {
        "jsCode": "const allRows = $input.all();\nconst extractedContacts = $items(\"Extract Contacts\");\nconst results = [];\n\nfor (const contactItem of extractedContacts) {\n  const contact = contactItem.json;\n  \n  const existingRow = allRows.find(row => {\n    const sheetFirst = String(row.json.first_name || row.json[\"first_name \"] || \"\").toLowerCase().trim();\n    const sheetTitle = String(row.json.designation || row.json[\"designation \"] || \"\").toLowerCase().trim();\n    \n    const contactFirst = String(contact.first_name || \"\").toLowerCase().trim();\n    const contactTitle = String(contact.designation || \"\").toLowerCase().trim();\n    \n    if (sheetFirst && contactFirst && sheetFirst === contactFirst && sheetTitle && contactTitle && sheetTitle === contactTitle) {\n        return true;\n    }\n\n    const sheetLinkedIn = String(row.json.linkedin_url || row.json[\"linkedin_url \"] || \"\").toLowerCase().replace(/^https?:\\/\\/(www\\.)?/, '');\n    const contactLinkedIn = String(contact.linkedin_url || \"\").toLowerCase().replace(/^https?:\\/\\/(www\\.)?/, '');\n    \n    if (sheetLinkedIn && contactLinkedIn && sheetLinkedIn === contactLinkedIn) {\n        return true;\n    }\n    \n    return false;\n  });\n\n  if (existingRow) {\n    results.push({\n      json: {\n        ...contact,\n        found: \"yes\",\n        status: \"Duplicate (Already Exists)\"\n      }\n    });\n  } else {\n    results.push({\n      json: {\n        ...contact,\n        found: \"no\"\n      }\n    });\n  }\n}\nreturn results;"
      },

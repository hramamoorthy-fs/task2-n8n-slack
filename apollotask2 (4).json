    {
      "parameters": {
        "jsCode": "for (const item of items) {\n  let url = item.json.website_url || item.json.website || \"\";\n  url = url.trim();\n  if (url) {\n    let domain = url.replace(/^(https?:\\/\\/)?(www\\.)?/, \"\");\n    domain = domain.split('/')[0].split('?')[0];\n    item.json.domain = domain.toLowerCase().trim();\n  } else {\n    item.json.domain = \"\";\n  }\n}\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

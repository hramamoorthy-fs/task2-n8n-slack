    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet combinedText = \"🚨 *Duplicate Leads Found (Already Exists)* 🚨\\n\\n\";\n\nfor (const item of items) {\n  const data = item.json;\n  combinedText += `*Name:* ${data.first_name || \"\"} ${data.last_name || \"\"}\\n`;\n  combinedText += `*Company:* ${data.company_name || \"\"}\\n`;\n  combinedText += `*Designation:* ${data.designation || \"\"}\\n`;\n  combinedText += `*Email:* ${data.email || \"N/A\"}\\n`;\n  combinedText += `*LinkedIn URL:* ${data.linkedin_url || \"N/A\"}\\n`;\n  combinedText += `--------------------------------------\\n`; // Adds a clean divider between leads\n}\n\n// Return a single item so Slack only fires once\nreturn [{\n  json: {\n    slack_message: combinedText\n  }\n}];"
      },
